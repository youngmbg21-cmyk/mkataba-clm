# HaTi — example environment configuration.
# Copy to `.env` and fill in real values. NEVER commit a real key.
# .env and .env.* are gitignored; this .env.example (placeholders only) is tracked.

# Anthropic API key that powers the AI features (Portfolio Intelligence graph,
# search, extraction, obligations, playbook review). An admin can also paste a
# key in Team & Settings, which is stored server-side and takes precedence.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional "override every tier" model. When set (and valid), it forces this one
# model for both the FAST and DEEP tiers. Leave unset to use the per-tier
# defaults / per-tier overrides configured in Team & Settings.
ANTHROPIC_MODEL=

# Resend API key — turns on real email delivery (invites, password resets,
# signing OTPs, renewal reminders). Without it, mail queues to an admin outbox.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From-address for outgoing email.
EMAIL_FROM=HaTi <no-reply@example.com>

# --- WhatsApp signing codes (optional) ---
# When a contract is shared over WhatsApp, the 6-digit signing code is delivered
# by WhatsApp to the number it was sent to (instead of email). This needs a
# WhatsApp Business API provider. Set both to turn on real delivery via Meta's
# WhatsApp Cloud API; without them, the code queues to the admin outbox (visible
# for testing), exactly like the email dev-code fallback.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Optional Graph API version (default v21.0).
WHATSAPP_API_VERSION=

# Directory for the SQLite database and stored files (default: server/data).
HATI_DATA=server/data

# HTTP port (default: 3000).
PORT=3000

# Set to true when running behind TLS / a reverse proxy. Enables secure cookies,
# HSTS, and an http->https redirect (honouring x-forwarded-proto). Leave unset
# for local http development.
HTTPS=
# TRUST_PROXY=true   # equivalent alternative to HTTPS=true

# --- AI cost controls (all also editable in Team & Settings, which wins) ---
# Per-user request caps per 15 min: light endpoints (search/graph/template/
# extract) and the pricier deep endpoints (playbook/obligations).
AI_RATE_LIGHT=40
AI_RATE_DEEP=15
# Whole-workspace daily AI-request ceiling; 0 disables the backstop.
AI_DAILY_LIMIT=500
# Per-request input caps: content characters, and contracts per portfolio call.
AI_MAX_CHARS=50000
AI_MAX_CONTRACTS=400
