# HaTi — example environment configuration.
# Copy to `.env` and fill in real values. NEVER commit a real key.
# .env and .env.* are gitignored; this .env.example (placeholders only) is tracked.

# Anthropic API key that powers the AI features (Portfolio Intelligence graph,
# search, extraction, obligations, playbook review). An admin can also paste a
# key in Team & Settings, which is stored server-side and takes precedence.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional "override every tier" model. When set (and valid), it forces this one
# model for both the FAST and DEEP tiers. Leave unset to use the per-tier
# defaults / per-tier overrides configured in Team & Settings.
ANTHROPIC_MODEL=

# Resend API key — turns on real email delivery (invites, password resets,
# signing OTPs, renewal reminders). Without it, mail queues to an admin outbox.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From-address for outgoing email.
EMAIL_FROM=HaTi <no-reply@example.com>

# Directory for the SQLite database and stored files (default: server/data).
HATI_DATA=server/data

# HTTP port (default: 3000).
PORT=3000
